<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Vehículos Disponibles</title>
    <link rel="icon" type="image/svg" href="../img/icon.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/accessibility.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
    <%- include('partials/navbar') %>
        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Vehículos Disponibles</h1>
            </div>

            <% if (vehiculos.length===0) { %>
                <div class="alert alert-info">No hay vehículos disponibles en tu concesionario en este momento.</div>
                <% } else { %>
                    <div class="row row-cols-1 row-cols-md-3 g-4">
                        <% vehiculos.forEach(v=> { %>
                            <div class="col">
                                <div class="card dashboard-card h-100">
                                    <div class="card-body">
                                        <h5 class="card-title text-center">
                                            <%= v.marca %>
                                            <%= v.modelo %>
                                        </h5>
                                        <h6 class="card-subtitle mb-2 text-muted text-center">
                                            <%= v.matricula %>
                                        </h6>
                                        <ul class="list-unstyled">
                                            <li>
                                                <div class="imagen-contenedor">
                                                    <img src="<%= v.imagen %>" alt="foto vehiculo" class="w-100" class="h-50">
                                                </div>
                                            </li>
                                            <li><strong>Plazas:</strong>
                                                <%= v.numero_plazas %>
                                            </li>
                                            <li><strong>Autonomía:</strong>
                                                <%= v.autonomia_km %> km
                                            </li>
                                            <li><strong>Color:</strong>
                                                <%= v.color %>
                                            </li>
                                        </ul>
                                        <a href="/empleado/reservar/<%= v.id_vehiculo %>"
                                            class="btn btn-primary w-100">Reservar</a>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                    </div>
                    <% } %>
        </div>
        <%- include('partials/footer') %>
            <%- include('partials/accessibility_modal') %>
                <script src="/js/bootstrap.bundle.min.js"></script>
                <script src="/js/accessibility.js"></script>
</body>

</html>