<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Vehículos Disponibles</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Vehículos en tu Base</h1>
            <a href="/empleado/dashboard" class="btn btn-secondary">Volver</a>
        </div>

        <% if (vehiculos.length === 0) { %>
            <div class="alert alert-info">No hay vehículos disponibles en tu concesionario en este momento.</div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                <% vehiculos.forEach(v => { %>
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title"><%= v.marca %> <%= v.modelo %></h5>
                                <h6 class="card-subtitle mb-2 text-muted"><%= v.matricula %></h6>
                                <ul class="list-unstyled">
                                    <li><strong>Plazas:</strong> <%= v.numero_plazas %></li>
                                    <li><strong>Autonomía:</strong> <%= v.autonomia_km %> km</li>
                                    <li><strong>Color:</strong> <%= v.color %></li>
                                </ul>
                                <a href="/empleado/reservar/<%= v.id_vehiculo %>" class="btn btn-primary w-100">Reservar</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>