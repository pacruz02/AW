<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Panel de Administración</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg" href="../img/icon.svg">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/accessibility.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">

    <%- include('partials/navbar') %>

        <div class="container mt-4">

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-7 text-center text-md-start mb-3 mb-md-0">
                            <h1 class="display-5">¡Bienvenido, <%= user.name %>!</h1>
                            <span class="badge bg-success fs-6">Admin</span>
                        </div>

                        <div class="col-md-4 imagen-contenedor">
                            <img src="/img/planceholder.png" alt="Foto del empleado"
                                class="img-fluid">
                        </div>
                    </div>
                </div>
            </div>
            <br>
            <div class="row g-3">

                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="/admin/carga-datos"
                        class="btn btn-primary btn-outline-dark w-100 h-100 py-4 d-flex align-items-center justify-content-center shadow-sm">
                        <span class="fs-5">Carga de datos</span>
                    </a>
                </div>

                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="/admin/vehiculos" accesskey="V"
                        class="btn btn-primary btn-outline-dark w-100 h-100 py-4 d-flex align-items-center justify-content-center shadow-sm">
                        <span class="fs-5">Vehículos</span>
                    </a>
                </div>

                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="/admin/concesionarios" accesskey="S"
                        class="btn btn-primary btn-outline-dark w-100 h-100 py-4 d-flex align-items-center justify-content-center shadow-sm">
                        <span class="fs-5">Sedes</span>
                    </a>
                </div>

                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="/admin/usuarios" accesskey="U"
                        class="btn btn-primary btn-outline-dark w-100 h-100 py-4 d-flex align-items-center justify-content-center shadow-sm">
                        <span class="fs-5">Usuarios</span>
                    </a>
                </div>

                <div class="col-12 col-md-8 col-lg-4">
                    <a href="/admin/estadisticas" accesskey="E"
                        class="btn btn-primary btn-outline-dark w-100 h-100 py-4 d-flex align-items-center justify-content-center shadow-sm">
                        <span class="fs-5">Estadísticas</span>
                    </a>
                </div>

            </div>
        </div>
        <br>
        <%- include('partials/footer') %>
            <%- include('partials/accessibility_modal') %>

                <script src="/js/bootstrap.bundle.min.js"></script>
                <script src="/js/accessibility.js"></script>
</body>

</html>