<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Panel de Administración</title>
    <link rel="icon" type="image/svg" href="../img/icon.svg">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/accessibility.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
    <%- include('partials/navbar') %>
        <div class="card">
            <div class="dashboard-card">
                <div>
                    <h1>¡Bienvenido, <%= user.name %>!</h1>
                    <em>Admin</em>
                </div>
                <div class="imagen-contenedor">
                    <img src="../img/planceholder.png" alt="Foto del empleado">
                </div>
            </div>
            <li>
                <a href="/admin/carga-datos">Carga Masiva de Datos (JSON)</a>
            </li>
            <li>
                <a class="nav-link" href="/admin/vehiculos" accesskey="V">Vehículos</a>
            </li>
            <li>
                <a class="nav-link" href="/admin/concesionarios" accesskey="S">Sedes</a>
            </li>
            <li>
                <a class="nav-link" href="/admin/usuarios" accesskey="U">Usuarios</a>
            </li>
            <li>
                <a class="nav-link" href="/admin/estadisticas" accesskey="E">Estadísticas</a>
            </li>
        </div>
        <%- include('partials/footer') %>
            <%- include('partials/accessibility_modal') %>
                <script src="/js/bootstrap.bundle.min.js"></script>
                <script src="/js/accessibility.js"></script>
</body>

</html>