<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>
        <%= concesionario ? 'Editar' : 'Nuevo' %> Concesionario
    </title>
    <link rel="icon" type="image/svg" href="../img/icon.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/accessibility.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
    <%- include('partials/navbar') %>
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h3>
                                <%= concesionario ? 'Editar Sede' : 'Añadir Nueva Sede' %>
                            </h3>
                        </div>
                        <div class="card-body">
                            <form
                                action="<%= concesionario ? '/admin/concesionarios/editar/' + concesionario.id_concesionario : '/admin/concesionarios/nuevo' %>"
                                method="POST">

                                <div class="mb-3">
                                    <label class="form-label">Nombre del Concesionario</label>
                                    <input type="text" class="form-control" name="nombre"
                                        value="<%= concesionario ? concesionario.nombre : '' %>" required>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Ciudad</label>
                                    <input type="text" class="form-control" name="ciudad"
                                        value="<%= concesionario ? concesionario.ciudad : '' %>" required>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Dirección</label>
                                    <input type="text" class="form-control" name="direccion"
                                        value="<%= concesionario ? concesionario.direccion : '' %>" required>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Teléfono de Contacto</label>
                                    <input type="tel" class="form-control" name="telefono"
                                        value="<%= concesionario ? concesionario.telefono_contacto : '' %>">
                                </div>

                                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                    <a href="/admin/concesionarios" class="btn btn-secondary me-md-2">Cancelar</a>
                                    <button type="submit" class="btn btn-primary">Guardar</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <%- include('partials/footer') %>
            <%- include('partials/accessibility_modal') %>
                <script src="/js/bootstrap.bundle.min.js"></script>
                <script src="/js/accessibility.js"></script>
</body>

</html>