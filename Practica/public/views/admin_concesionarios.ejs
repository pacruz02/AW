<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestión de Concesionarios - Admin</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1>Concesionarios</h1>
            <div>
                <a href="/admin/concesionarios/nuevo" class="btn btn-success">Nueva Sede</a>
                <a href="/admin/dashboard" class="btn btn-secondary">Volver</a>
            </div>
        </div>

        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Ciudad</th>
                    <th>Dirección</th>
                    <th>Teléfono</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (concesionarios.length === 0) { %>
                    <tr><td colspan="5" class="text-center">No hay concesionarios registrados.</td></tr>
                <% } else { %>
                    <% concesionarios.forEach(c => { %>
                        <tr>
                            <td><%= c.nombre %></td>
                            <td><%= c.ciudad %></td>
                            <td><%= c.direccion %></td>
                            <td><%= c.telefono_contacto %></td>
                            <td>
                                <a href="/admin/concesionarios/editar/<%= c.id_concesionario %>" class="btn btn-sm btn-primary">Editar</a>
                                <form action="/admin/concesionarios/borrar/<%= c.id_concesionario %>" method="POST" style="display:inline;" onsubmit="return confirm('¿Eliminar esta sede?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Borrar</button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>
    </div>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>