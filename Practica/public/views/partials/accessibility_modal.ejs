<button type="button" class="btn btn-outline-secondary position-fixed bottom-0 end-0 m-3" data-bs-toggle="modal" data-bs-target="#accessibilityModal" aria-label="Opciones de Accesibilidad">
    Accesibilidad
</button>

<div class="modal fade" id="accessibilityModal" tabindex="-1" aria-labelledby="accModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="accModalLabel">Opciones de Accesibilidad</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <h6>Contraste</h6>
                <div class="btn-group w-100 mb-3" role="group">
                    <button type="button" class="btn btn-light border" id="btn-contrast-normal">Normal</button>
                    <button type="button" class="btn btn-dark" id="btn-contrast-high">Alto Contraste</button>
                </div>

                <h6>Tamaño de letra</h6>
                <div class="btn-group w-100" role="group">
                    <button type="button" class="btn btn-outline-primary" id="btn-font-small">A-</button>
                    <button type="button" class="btn btn-outline-primary" id="btn-font-normal">A</button>
                    <button type="button" class="btn btn-outline-primary" id="btn-font-large">A+</button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>