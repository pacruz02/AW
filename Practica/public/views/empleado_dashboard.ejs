<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Empleado</title>
    <link rel="icon" type="image/svg" href="/img/icon.svg">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/accessibility.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">

    <%- include('partials/navbar') %>

        <div class="container mt-4">

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-7 text-center text-md-start mb-3 mb-md-0">
                            <h1 class="display-5">¡Bienvenido, <%= user.name %>!</h1>
                            <span class="badge bg-success fs-6">Empleado</span>
                        </div>

                        <div class="col-md-4 imagen-contenedor">
                            <img src="/img/planceholder.png" alt="Foto del empleado" class="img-fluid">
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="card-title mb-0">Mis Reservas</h3>
                    </div>

                    <hr>

                    <% if (reservas.length===0) { %>
                        <div class="alert alert-info" role="alert">
                            ¡Aún no tienes reservas! <a href="/empleado/vehiculos" class="alert-link">Haz tu primera
                                reserva aquí</a>.
                        </div>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr class="text-center">
                                            <th>Vehículo</th>
                                            <th class="col-2">Imágen</th>
                                            <th>Fechas</th>
                                            <th>Estado</th>
                                            <th>Kms</th>
                                        </tr>
                                    </thead>
                                    <tbody class="align-middle">
                                        <% reservas.forEach(r=> { %>
                                            <tr class="text-center">
                                                <td class="ps-3">
                                                    <div class="align-items-center">
                                                        <div>
                                                            <div class="fw-bold">
                                                                <%= r.marca %>
                                                                    <%= r.modelo %>
                                                            </div>
                                                            <small class="text-muted">
                                                                <%= r.matricula %>
                                                            </small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="d-flex align-items-center justify-content-center h-100">
                                                    <img src="<%= r.imagen %>"
                                                        class="rounded img-fluid">
                                                </td>
                                                <td>
                                                    <div class="small">
                                                        <span class="d-block">Incio: <%= new
                                                                Date(r.fecha_inicio).toLocaleDateString() %></span>
                                                        <span class="d-block text-muted">Fin: <%= new
                                                                Date(r.fecha_fin).toLocaleDateString() %></span>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span>
                                                        <%= r.estado.toUpperCase() %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <%= r.kilometros_recorridos ? r.kilometros_recorridos + ' km' : '-'
                                                        %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <% } %>
                </div>
            </div>
        </div>
        <br>
        <%- include('partials/footer') %>
            <%- include('partials/accessibility_modal') %>
                <script src="/js/bootstrap.bundle.min.js"></script>
                <script src="/js/accessibility.js"></script>
</body>

</html>